# See src/env.ts for the source of truth on each variable
# (scope, whether it's required, default, and what it's used for).

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database (required)
DATABASE_URL="postgresql://username:password@localhost:5432/database"

# BetterAuth (required)
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000" # Base URL of your app

# Google OAuth (required for social login)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email — Resend. Required in all environments. Get a key at resend.com.
RESEND_API_KEY=""

# Sentry (optional in dev; required in prod for error tracking + source maps)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
