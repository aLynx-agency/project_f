{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":semanticCommits"],
  "labels": ["dependencies"],
  "rangeStrategy": "bump",
  "schedule": ["before 6am on monday"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "packageRules": [
    {
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "matchCurrentVersion": "!/^0/",
      "automerge": false,
      "groupName": "non-major dependencies"
    },
    {
      "matchPackagePatterns": ["^@types/"],
      "groupName": "types"
    },
    {
      "matchPackagePatterns": ["eslint", "prettier", "lint-staged", "husky", "commitlint"],
      "groupName": "lint/format tooling"
    },
    {
      "matchPackagePatterns": ["^@sentry/"],
      "groupName": "sentry"
    },
    {
      "matchPackagePatterns": ["^vitest", "^@vitest/", "@testing-library/"],
      "groupName": "test tooling"
    },
    {
      "matchPackageNames": ["next", "react", "react-dom"],
      "groupName": "next + react",
      "schedule": ["before 6am on first day of month"]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  }
}
